{
  "name": "new_apple_bobs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:go": "bash scripts/dev.sh",
    "dev:server": "pnpm --dir server dev",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "check": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json",
    "build": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json && vite build",
    "preview": "vite preview",
    "start": "pnpm --dir server start"
  },
  "devDependencies": {
    "@types/pathfinding": "^0.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.178.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "pathfinding": "^0.4.18",
    "pnpm": "^11.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "three": "^0.178.0"
  }
}
